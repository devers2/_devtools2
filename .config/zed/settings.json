{
  "vim_mode": true,
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_features": {
    "calt": true
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Kanagawa Wave"
  },
  "tab_size": 2,
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "languages": {
    "Java": {
      "language_servers": ["jdtls"]
    }
  },
  "lsp": {
    "jdtls": {
      "settings": {
        // Gradle 관련
        "jdk_auto_download": false
      },
      "initialization_options": {
        "settings": {
          "java": {
            "import": {
              "gradle": {
                "enabled": true,
                "wrapper": {
                  "enabled": true
                }
              }
            },
            "configuration": {
              "updateBuildConfiguration": "automatic"
            }
          }
        }
      }
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
