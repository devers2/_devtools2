{
  // ==============================================================================
  // 🌟 [Zed 확장 프로그램 자동 설치 및 동기화 설정]
  // - 새로운 확장을 설치 및 동기화하려면 아래 목록에 "확장명": true 를 추가한 뒤 Git에 저장하세요.
  // - "확장명"은 운영체제별로 아래 디렉토리에서 확장명을 확인할 수 있음(설치된 확장 디렉토리명 확인)
  //   [Windows] %LOCALAPPDATA%\Zed\extensions\installed
  //   [Linux] ~/.local/share/zed/extensions/
  //   [WSL] ~/.local/share/zed/remote_extensions/
  //   (예: "kotlin": true, "docker": true)
  // ==============================================================================
  "auto_install_extensions": {
    // [테마 확장]
    "kanagawa-themes": true,

    // [Spring Boot / Gradle 개발 필수]
    "java": true,       // Java 언어 지원
    "html": true,
    "xml": true,        // Spring XML/pom.xml 설정 지원

    // [기타 프로젝트 지원]
    "toml": true,       // tool-versions.toml 등 설정용
    "powershell": true  // PowerShell 쉘 스크립트 지원
  },

  "vim_mode": true,
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "buffer_font_features": {
    "calt": true
  },
  "theme": {
    "mode": "system",
    "light": "Kanagawa Dragon",
    "dark": "Kanagawa Wave"
  },
  "tab_size": 2,
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "preferred_line_length": 120,
  "soft_wrap": "preferred_line_length",
  "languages": {
    "Java": {
      "language_servers": ["jdtls"]
    }
  },
  "lsp": {
    "jdtls": {
      "settings": {
        // Gradle 관련
        "jdk_auto_download": false
      },
      "initialization_options": {
        "settings": {
          "java": {
            "import": {
              "gradle": {
                "enabled": true,
                "wrapper": {
                  "enabled": true
                }
              }
            },
            "configuration": {
              "updateBuildConfiguration": "automatic"
            }
          }
        }
      }
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
