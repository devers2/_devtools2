# ------------------------------------
# 캐시 폴더
**/.cache/
**/.npm/
**/.yarn/
**/.pnp.*
**/.turbo/
**/.parcel-cache/
**/build-cache/
**/dependency-cache/
**/.venv/
**/venv/
**/__pycache__/

# 로그 및 임시 파일
**/*.log
**/*.pid
**/*.swp
**/*.tmp
**/*~
**/logs/
**/temp/
**/tmp/

