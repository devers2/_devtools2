    "**/lazy-lock.json": true,

    // 기타 빌드 도구 부산물
    "**/.vercel/**": true,
    "**/.next/**": true
  },

  /* 검색 설정: VS Code의 검색 기능(예: Ctrl+Shift+F로 전체 프로젝트 검색)에서 특정 파일/폴더를 제외 (파일 감시나 탐색기 표시에는 영향을 주지 않음) */
  "search.exclude": {
    // Git/버전 관리
    "**/.git/**": true,
    "**/.svn/**": true,

    // 빌드 출력
    "**/*.class": true,
    "**/*.jar": true,
    "**/*.war": true,
    "**/*.ear": true,
    "**/build/**": true,
    "**/target/**": true,
    "**/out/**": true,
    "**/bin/**": true,
    "**/classes/**": true,
    "**/dist/**": true,
    "**/generated/**": true,
    "**/generated-sources/**": true,

    // Gradle/Maven
    "**/.gradle/**": true,
    "**/.mvn/**": true,
    "**/.m2/repository/**": true,

    // 의존성 & 캐시
    "**/node_modules/**": true, // 필수 숨김 필요
    "**/.cache/**": true,
    "**/.npm/**": true,
    "**/.yarn/**": true,
    "**/.pnp.*": true,
    "**/.turbo/**": true,
    "**/.parcel-cache/**": true,
    "**/bower_components/**": true,
    "**/build-cache/**": true,
    "**/dependency-cache/**": true,

    // 언어별 환경
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/__pycache__/**": true,
    "**/*.egg-info/**": true,
    "**/*.pyc": true,
    "**/pkg/**": true,
    "**/.serverless/**": true,

    // IDE 관련
    "**/.vscode/**": false, // VS Code 설정 디렉토리
    "**/.vscode-server/**": true,
    "**/.vscode-test/**": true,
    "**/.idea/**": true, // IntelliJ IDEA 설정 디렉토리
    "**/.classpath": true,
    "**/.eclipse/**": true,
    "**/.factorypath": true,
    "**/*.iml": true,
    "**/.metadata/**": true,
    "**/.project": true,
    "**/.settings/**": true,
    "**/.vs/**": true,
    "**/nbproject/**": true,

    // 로그 & 임시/백업
    "**/*.bak": true,
    "**/*.log": true,
    "**/*.pid": true,
    "**/*.swp": true,
    "**/*.tmp": true,
    "**/*~": true,
    "**/logs/**": true,
    "**/temp/**": true,
    "**/tmp/**": true,

    // 테스트/정적/데이터베이스
    "**/coverage/**": true,
    "**/jacoco/**": true,
    "**/test-output/**": true,
    "**/test-reports/**": true,
    "**/.nyc_output/**": true,
    "**/*.db": true,
    "**/*.sqlite": true,
    "**/*.h2.db": true,
    "**/h2/**": true,

    // OS
    "**/.DS_Store": true,
    "**/.fseventsd/**": true,
    "**/.Spotlight-V100/**": true,
    "**/.Trash/**": true,
    "**/.Trashes/**": true,
    "**/Thumbs.db": true,
    "**/desktop.ini": true,
    "**/$RECYCLE.BIN/**": true,

    // Python 캐시 및 환경
    "**/.uv/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,

    //Java JDTLS 내부 인덱스 및 세션
    "**/.jdtjsData/**": true
  },
  "search.useIgnoreFiles": true, // .gitignore 및 .ignore 파일에 정의된 경로를 검색에서 제외 → true: 활성화 시 .gitignore/.ignore에 설정된 파일과 폴더는 검색 결과에서 제외됨
  "search.useGlobalIgnoreFiles": true, // 전역 .gitignore 및 .ignore 파일에 정의된 경로를 검색에서 제외 → true: 활성화 시 사용자 홈 디렉토리의 전역 .gitignore/.ignore 설정도 검색 결과에서 제외됨

  /* Java 인덱싱 제외 설정 (언어 서버 부하 감소) */
  "java.import.exclusions": [
    /* 빌드 및 출력 폴더 (필수 제외) */
    "**/node_modules/**",
    "**/build/**",
    "**/target/**",
    "**/bin/**",
    "**/out/**",
    "**/.metadata/**",

    /* 버전 관리 및 IDE 설정 */
    "**/.git/**",
    "**/.svn/**",
    "**/.idea/**",
    "**/.vscode/**",
    "**/.settings/**",
    "**/.project",
    "**/.classpath",

    /* 타 언어 환경 (딱풀 프로젝트 등 Python 병행 시) */
    "**/.venv/**",
    "**/venv/**",
    "**/__pycache__/**",
    "**/.uv/**",

    /* 기타 불필요한 리소스 */
    "**/archetype-resources/**",
    "**/META-INF/maven/**",
    "**/help-doc/**",
    "**/doc/**"
  ],

  /* 언어별 포맷터/린팅 설정 */
  "[java]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "redhat.java" // Red Hat 포맷터 사용
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff", // 기본 포맷터를 Ruff로 지정
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.ruff": "explicit", // 저장 시 Ruff가 찾은 모든 오류 자동 교정
      "source.organizeImports.ruff": "explicit" // 저장 시 라이브러리(import) 자동 정렬/최적화
    }
  },
  "[javascript]": {
    // "editor.defaultFormatter": "vscode.typescript-language-features" // VS Code 기본 TypeScript 포맷터 사용
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascriptreact]": {
    // "editor.defaultFormatter": "vscode.typescript-language-features" // VS Code 기본 TypeScript 포맷터 사용
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescript]": {
    // "editor.defaultFormatter": "vscode.typescript-language-features" // VS Code 기본 TypeScript 포맷터 사용
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    // "editor.defaultFormatter": "vscode.typescript-language-features" // VS Code 기본 TypeScript 포맷터 사용
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.eslint": "explicit"
    }
  },
  "[json]": {
    // "editor.defaultFormatter": "vscode.json-language-features" // VS Code 기본 HTML 포맷터 사용
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    // "editor.defaultFormatter": "vscode.json-language-features" // VS Code 기본 HTML 포맷터 사용
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features", // VS Code 기본 HTML 포맷터 사용
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.eslint": "explicit"
    }
  },
  "[css]": {
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.stylelint": "explicit"
    }
  },
  "[scss]": {
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.stylelint": "explicit"
    }
  },
  "[less]": {
    "editor.codeActionsOnSave": {
      // 저장할 때 코드 액션(린터)이 제안하는 수정/정리 실행 지시
      "source.fixAll.stylelint": "explicit"
    }
  },
  "[xml]": {
    // "editor.defaultFormatter": "DotJoshJohnson.xml" // XML Tools 포맷터 사용
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode"
  },
  "[sql]": {
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode" // Prettier SQL 포맷터 사용
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml" // Red Hat YAML 포맷터 사용
  },
  "[dockercompose]": {
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[kotlin][kotlinscript]": {
    "editor.tabSize": 4
  },
  "[groovy][gradle]": {
    "editor.tabSize": 4
  },

  /* HTML 설정 */
  "html.format.enable": true, // 내장 포맷터 활성화 (기본 true)
  "html.format.unformatted": "script", // HTML 포맷터가 포맷하지 않을 태그 목록 → "script": <script> 태그 내 코드는 포맷하지 않음(기본 포맷터인 Prettier가 동작), "script,pre": <pre> 태그 등 추가 가능 , "" : 모든 태그 포맷팅
  "html.format.wrapAttributes": "force-aligned", // HTML 속성의 줄 바꿈 방식 → "auto", "force", force-aligned", "force-expand-multiline"
  "html.format.wrapLineLength": 100, // HTML 코드 줄 바꿈 기준 길이 → 100: Prettier printWidth와 통일
  "html.format.indentInnerHtml": true, // <body> 및 <head> 내부 들여쓰기 → true: 활성화
  "html.format.extraLiners": "head,body,/html", // HTML 포맷터가 빈 줄을 추가할 태그 목록 → "head,body,/html": <head>, <body>, </html> 태그 앞에 빈 줄 추가(기본값)

  /* 포맷터/Lint 설정 */
  "prettier.resolveGlobalModules": true, // 전역 모듈에서 Prettier 찾기 활성화
  "prettier.requireConfig": true, // .prettierrc 필수로 사용 → true: 활성화(Prettier 설정 파일이 없으면 포맷터로 동작하지 않음)
  "eslint.enable": true, // ESLint 활성화
  "eslint.run": "onSave", // ESLint 실행 시점 설정 → "onSave": 파일 저장 시점에 린트 실행, "onType": 코드를 타이핑하는 도중 실시간으로 린트 실행
  "eslint.format.enable": true, // ESLint를 포맷터로 사용
  "eslint.workingDirectories": ["./"],
  "eslint.validate": [
    // ESLint가 검사할 파일 형식
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "vue"
  ],
  "stylelint.enable": true, // Stylelint 활성화
  "stylelint.run": "onSave", // Stylelint 실행 시점 설정 → "onSave": 파일 저장 시점에 린트 실행, "onType": 코드를 타이핑하는 도중 실시간으로 린트 실행
  "stylelint.validate": ["css", "scss", "less", "vue"], // Stylelint가 검사할 파일 형식
  "stylelint.reportInvalidScopeDisables": false, // Stylelint의 잘못된 범위 비활성화 보고서 비활성화
  "stylelint.reportNeedlessDisables": false, // Stylelint의 불필요한 비활성화 보고서 비활성화
  "css.validate": false, // CSS 기본 유효성 검사 비활성화 → Stylelint에게 위임

  /* Git 설정 */
  "git.enabled": true, // VS Code 내장 Git 소스 제어 기능 활성화 여부
  "git.autofetch": true, // Git 자동 fetch → true: 활성화
  "git.confirmSync": false, // Git 동기화 시 확인 메시지 → false: 비활성화
  "git.useEditorAsCommitInput": false, // 커밋 메시지 입력 시 에디터 사용 → false: 비활성화
  "git.enableSmartCommit": true, // Stage되지 않은 변경 사항도 커밋 여부 → true: 활성화
  "git.openRepositoryInParentFolders": "always", // 상위 폴더의 Git 저장소 열기 → "always": 항상 열기, "never": 열지 않음, "smart": 자동 감지
  "git.blame.editorDecoration.enabled": false, // 편집기 주석 Blame (Editor Decoration) 활성화 여부 → 연속 단축키 Ctrl + Alt + B, Ctrl + Alt + E 로 토글 가능
  "git.blame.statusBarItem.enabled": true, // 상태 표시줄 Blame (Status Bar Item) 활성화 여부 → 연속 단축키 Ctrl + Alt + B, Ctrl + Alt + S 로 토글 가능
  "gitlens.ai.model": "vscode", // GitLens AI 확장팩에서 사용할 모델 설정
  "gitlens.ai.vscode.model": "copilot:gpt-4.1", // GitLens AI 확장팩에서 VS Code Copilot 모델 사용
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "fileHistory": false,
    "repositories": true,
    "searchAndCompare": false,
    "launchpad": false
  },

  /* Gradle 설정 */
  "gradle.nestedProjects": true, // Gradle 중첩 프로젝트 지원 → true: 활성화
  "explorer.compactFolders": false, // 탐색기에서 폴더 압축 여부 → false: 비활성화
  "explorer.confirmDelete": true, // 파일 삭제 시 확인 메시지 표시 → true: 활성화
  "breadcrumbs.enabled": true, // 경로 탐색 → true: 활성화

  /* 기타 확장 설정 */
  "workbench.iconTheme": "material-icon-theme", // 아이콘 테마 설정
  "workbench.startupEditor": "none", // 시작 시 새 Untitled 파일 열기 → "none": 비활성화
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 20, // 열 수 있는 탭의 최대 개수 → 20: 20개
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.html": "default"
  },
  "window.openFoldersInNewWindow": "on", // 폴더 열기시 새창에서 열기 여부 → "on": 항상 새 창에서 열기, "off": 항상 현재 창에서 열기
  "sqltools.connections": [],
  "cSpell.userWords": []
}
