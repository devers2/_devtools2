#!/bin/bash
# ==============================================================================
# 리눅스 환경용 pwsh.exe 우회 래퍼 스크립트
#
# 목적: 
#   Windows 와 Linux 간에 Ghostty 설정 파일(config.ghostty)을 심볼릭 링크로 
#   동일하게 공유하여 사용할 때, `command = "pwsh.exe"` 설정으로 인해
#   리눅스 Ghostty가 실행 실패(바이너리 없음)하는 오류를 방지하기 위해 존재합니다.
#
# 작동 방식:
#   리눅스 환경에서 Ghostty 가 pwsh.exe 를 찾으면, 이 스크립트가 실행되어
#   대신 기본 bash 로그인 쉘을 실행합니다.
# ==============================================================================

# 기본 쉘(bash)로 대치하여 실행 (로그인 쉘로 실행하여 .bashrc 로드 보장)
exec bash -l "$@"
