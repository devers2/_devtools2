#!/bin/bash
# ==============================================================================
# Windows Zed 에디터 실행 및 설정 실시간 동기화 래퍼 스크립트 (zed)
# ==============================================================================

# 경로 설정
WSL_CONFIG_DIR="/var/opt/_devtools2/.config/zed"
WIN_CONFIG_DIR="/mnt/c/Users/eseun/AppData/Roaming/Zed"

# WSL2 환경 감지
IS_WSL2=false
if grep -qi 'microsoft' /proc/version 2>/dev/null; then
    IS_WSL2=true
fi

# 리눅스 네이티브 환경인 경우 래퍼를 건너뛰고 원래의 리눅스용 Zed 에디터를 직접 실행합니다.
if [ "$IS_WSL2" = false ]; then
    if [ -f "/var/opt/_devtools2/modules/zed/zed" ]; then
        exec "/var/opt/_devtools2/modules/zed/zed" "$@"
    fi
    REAL_ZED=$(which -a zed 2>/dev/null | grep -v "/scripts/linux/cmd/zed" | head -n 1)
    if [ -n "$REAL_ZED" ]; then
        exec "$REAL_ZED" "$@"
    else
        echo "[오류] 실제 Zed 실행 파일을 찾을 수 없습니다."
        exit 1
    fi
fi

# 윈도우용 Zed 실행 파일 경로 탐색
ZED_EXE=""
if [ -f "/mnt/c/Users/eseun/AppData/Local/Programs/Zed/bin/zed.exe" ]; then
    ZED_EXE="/mnt/c/Users/eseun/AppData/Local/Programs/Zed/bin/zed.exe"
elif [ -f "/mnt/c/Users/eseun/AppData/Local/Zed/bin/zed.exe" ]; then
    ZED_EXE="/mnt/c/Users/eseun/AppData/Local/Zed/bin/zed.exe"
elif [ -f "/mnt/c/Program Files/Zed/Zed.exe" ]; then
    ZED_EXE="/mnt/c/Program Files/Zed/Zed.exe"
fi

if [ -z "$ZED_EXE" ]; then
    echo "[오류] 윈도우용 Zed 에디터 실행 파일을 찾을 수 없습니다."
    exit 1
fi

# 윈도우 설정 폴더가 없으면 생성
mkdir -p "$WIN_CONFIG_DIR"

# 동기화 함수 (수정 일자를 비교하여 더 최신 파일로 동기화)
sync_files() {
    local src="$1"
    local dest="$2"
    
    if [ -f "$src" ] && [ -f "$dest" ]; then
        local mtime_src=$(stat -c %Y "$src")
        local mtime_dest=$(stat -c %Y "$dest")
        
        if [ "$mtime_src" -gt "$mtime_dest" ]; then
            cp -f "$src" "$dest"
        elif [ "$mtime_dest" -gt "$mtime_src" ]; then
            cp -f "$dest" "$src"
        fi
    elif [ -f "$src" ]; then
        cp -f "$src" "$dest"
    elif [ -f "$dest" ]; then
        cp -f "$dest" "$src"
    fi
}

# 1. 실행 직전 초기 동기화
sync_files "$WSL_CONFIG_DIR/settings.json" "$WIN_CONFIG_DIR/settings.json"
sync_files "$WSL_CONFIG_DIR/keymap.json" "$WIN_CONFIG_DIR/keymap.json"

# 2. 인자 경로를 윈도우 포맷으로 변환하여 Zed 실행
ARGS=()
for arg in "$@"; do
    if [ -e "$arg" ]; then
        ARGS+=("$(wslpath -w "$arg")")
    else
        ARGS+=("$arg")
    fi
done

# 윈도우 Zed 에디터 백그라운드 구동
"$ZED_EXE" "${ARGS[@]}" &

# 3. Zed 에디터 실행 중에만 실시간 동기화 루프 작동 (종료 감시)
while true; do
    # tasklist.exe를 호출하여 zed.exe 프로세스 잔존 여부 확인
    if ! tasklist.exe 2>/dev/null | grep -qi "zed.exe"; then
        break
    fi
    
    # 2초 주기로 설정 양방향 동기화
    sync_files "$WSL_CONFIG_DIR/settings.json" "$WIN_CONFIG_DIR/settings.json"
    sync_files "$WSL_CONFIG_DIR/keymap.json" "$WIN_CONFIG_DIR/keymap.json"
    sleep 2
done

# 4. 최종 종료 전 피드백 동기화
sync_files "$WSL_CONFIG_DIR/settings.json" "$WIN_CONFIG_DIR/settings.json"
sync_files "$WSL_CONFIG_DIR/keymap.json" "$WIN_CONFIG_DIR/keymap.json"
